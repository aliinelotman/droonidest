{
  "id": null,
  "title": "Spring Boot Backend Dashboard",
  "tags": ["spring-boot", "backend"],
  "timezone": "browser",
  "panels": [
    {
      "id": 1,
      "title": "JVM Memory Usage",
      "type": "graph",
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{job=\"spring-boot\"}",
          "legendFormat": "{{area}}",
          "refId": "A"
        }
      ],
      "datasource": "Prometheus",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      }
    },
    {
      "id": 2,
      "title": "HTTP Request Rate",
      "type": "graph",
      "targets": [
        {
          "expr": "http_server_requests_seconds_count{job=\"spring-boot\"}",
          "legendFormat": "{{method}} {{uri}}",
          "refId": "A"
        }
      ],
      "datasource": "Prometheus",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      }
    },
    {
      "id": 3,
      "title": "Application Logs",
      "type": "logs",
      "targets": [
        {
          "expr": "{job=\"spring-boot\"}",
          "refId": "A"
        }
      ],
      "datasource": "Loki",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 8
      }
    }
  ],
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {},
  "templating": {
    "list": []
  },
  "annotations": {
    "list": []
  },
  "refresh": "5s",
