POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=

MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=

S3_ACCESS_KEY=
S3_SECRET_KEY=

SPRING_PROFILES_ACTIVE=local

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Production: your public site URL + /auth/callback (or backend callback URL)
GOOGLE_REDIRECT_URI=http://localhost:4200/auth/callback

# JWT — minimum 32 characters (use: openssl rand -base64 32)
JWT_SECRET=

# Comma-separated origins for browser requests (production: https://yourdomain)
CORS_ALLOWED_ORIGINS=http://localhost:4200

# Grafana admin credentials (required for production compose)
GRAFANA_ADMIN_USER=
GRAFANA_ADMIN_PASSWORD=
